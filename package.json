    "client:dev": "cd client && npm run dev",
    "setup": "npm install && npm run client:install && npm run client:build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "mongoose": "^8.9.0",
    "openai": "^4.47.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
