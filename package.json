{
  "name": "magicpin-vera-bot",
  "version": "2.0.0",
  "description": "magicpin AI Challenge Vera Merchant assistant bot — Node.js/Express + MongoDB + React",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "client:install": "cd client && npm install",
