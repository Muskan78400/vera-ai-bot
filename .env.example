# Server Port
PORT=8080

# MongoDB (optional)
# Leave empty to run with an in-memory store — nothing else changes, the
# server works exactly the same, it just won't persist data across restarts.
# For MongoDB Atlas (free tier): https://www.mongodb.com/cloud/atlas/register
# Connection string looks like:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vera_bot
MONGODB_URI=

# LLM Configuration
# Choose "gemini" (recommended) or "openai"
LLM_PROVIDER=gemini

# API Keys (Provide at least one based on LLM_PROVIDER)
# NOTE: this file is .env.example — never commit a real key here.
# If a real key was ever committed to this file in git history, rotate it
# in Google AI Studio immediately, since it's exposed to anyone with repo access.
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=

# LLM Model overrides (optional, defaults are gemini-2.5-flash and gpt-4o-mini)
# gemini-1.5-flash and all Gemini 1.0/1.5 models are permanently shut down
# (404 on every call) — do not use them. gemini-2.5-flash is current stable;
# gemini-3.5-flash is the newest generation if you want to upgrade further.
GEMINI_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
